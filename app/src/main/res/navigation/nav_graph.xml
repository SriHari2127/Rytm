<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/habitsFragment">

    <fragment
        android:id="@+id/habitsFragment"
        android:name="com.rytm.app.ui.habits.HabitsFragment"
        android:label="Habits"
        tools:layout="@layout/fragment_habits">
        <action
            android:id="@+id/action_habits_to_add_edit_habit"
            app:destination="@id/addEditHabitFragment"/>
    </fragment>

    <fragment
        android:id="@+id/addEditHabitFragment"
        android:name="com.rytm.app.ui.habits.AddEditHabitFragment"
        android:label="Add / Edit Habit"
        tools:layout="@layout/fragment_add_edit_habit">
        <argument
            android:name="habitId"
            app:argType="long"
            android:defaultValue="-1L"/>
    </fragment>

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.rytm.app.ui.analytics.AnalyticsFragment"
        android:label="Analytics"
        tools:layout="@layout/fragment_analytics"/>

    <fragment
        android:id="@+id/waterReminderFragment"
        android:name="com.rytm.app.ui.water.WaterReminderFragment"
        android:label="Water Reminder"
        tools:layout="@layout/fragment_water_reminder"/>

</navigation>