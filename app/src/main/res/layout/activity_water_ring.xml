<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_gradient">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48dp">

            <!-- Branding -->
            <TextView
                android:id="@+id/tv_branding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="· R Y T M ·"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:letterSpacing="0.4"
                android:alpha="0.7"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Hero Area -->
            <FrameLayout
                android:id="@+id/hero_container"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_branding"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/iv_water_ring_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@drawable/neon_ring_premium"
                    android:alpha="0.3"
                    app:tint="@color/neon_blue"/>

                <ImageView
                    android:id="@+id/iv_water_ring"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center"
                    android:scaleType="centerInside"
                    android:src="@drawable/neon_ring_premium"
                    app:tint="@color/neon_blue" />

                <ImageView
                    android:id="@+id/iv_water_icon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_water_drop_premium"/>
            </FrameLayout>

            <!-- Motivation Text -->
            <LinearLayout
                android:id="@+id/motivation_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/hero_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIME TO HYDRATE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.2"/>

                <TextView
                    android:id="@+id/tv_main_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drink Water"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tv_water_amount_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stay fresh, stay focused."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your body will thank you! 💧"
                    android:textColor="@color/neon_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Water Stats Card -->
            <FrameLayout
                android:id="@+id/water_stats_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_glass_card"
                app:layout_constraintTop_toBottomOf="@id/motivation_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:baselineAligned="false">

                    <!-- Remaining ML -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_water_drop_premium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REMAINING"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:id="@+id/tv_water_stat_remaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1500ml"
                            android:textColor="@color/neon_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Glasses Done -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_check_circle_premium"
                            app:tint="@color/neon_green"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GLASSES"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:id="@+id/tv_water_stat_glasses"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 done"
                            android:textColor="@color/neon_green"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Hydration Level -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_trending_up"
                            app:tint="@color/neon_purple"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GOAL %"
                            android:textColor="@color/text_secondary"
                            android:textSize="8sp"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:id="@+id/tv_water_stat_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45%"
                            android:textColor="@color/neon_purple"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:id="@+id/actions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/water_stats_card">

                <!-- Done -->
                <FrameLayout
                    android:id="@+id/btn_complete_card"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_button_done">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="32dp"
                            android:src="@drawable/ic_check_circle_premium"
                            app:tint="@color/white"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Log as Drunk"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Great job! Stay hydrated."
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </RelativeLayout>
                </FrameLayout>

                <!-- Skip -->
                <FrameLayout
                    android:id="@+id/btn_skip_card"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_skip_water">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="32dp"
                            android:src="@drawable/ic_skip_premium"
                            app:tint="@color/white"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Skip this One"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="I'll catch you on the next glass."
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </RelativeLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_bottom_quote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginHorizontal="24dp"
                    android:text="“ Pure water is the world's first and foremost medicine. ”"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:alpha="0.8"
                    android:paddingBottom="24dp"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
